PORT=3000
NODE_ENV=development

# Persist SQLite DB, sessions, and uploads on disk (survives app restarts).
# Local dev: keep ./data (created automatically; listed in .gitignore).
# Railway: attach a volume (e.g. mount at /data) and set DATA_DIR=/data
DATA_DIR=./data

SESSION_SECRET=change-this-secret

# Optional explicit paths (override DATA_DIR defaults):
# DB_PATH=./data/auction.db
# SESSION_DB_PATH=./data/sessions.sqlite
# UPLOADS_DIR=./data/uploads

# Optional upload limits:
# MAX_MEDIA_FILES=8
# MAX_MEDIA_FILE_MB=50
# MAX_AUCTION_COVER_MB=12

ADMIN_NAME=Platform Admin
ADMIN_EMAIL=admin@auction.local
ADMIN_PASSWORD=admin123
