<%- include("partials/header", { title, user, notice, formError: null }) %>

<section class="page-header">
  <h1><%= title %></h1>
  <p>Browse the auction catalogue. Pick an auction to see the items up for bid.</p>
</section>

<%
  function renderAuctionGroup(heading, list, emptyText, ctaLabel) {
%>
  <section class="section auction-group">
    <div class="auction-group-header">
      <h2><%= heading %></h2>
      <span class="auction-group-count"><%= list.length %></span>
    </div>
    <% if (!list.length) { %>
      <p class="muted"><%= emptyText %></p>
    <% } else { %>
      <div class="grid">
        <% list.forEach((auction) => { %>
          <article class="card auction-card">
            <div class="card-header">
              <h3><%= auction.name %></h3>
              <span class="badge <%= auction.status === 'open' ? 'badge-open' : 'badge-closed' %>">
                <%= (auction.status || '').toUpperCase() %>
              </span>
            </div>
            <p class="muted"><%= auction.description || "No description provided." %></p>
            <dl class="detail-list">
              <div>
                <dt>Starts</dt>
                <dd><%= new Date(auction.start_at).toLocaleString() %></dd>
              </div>
              <div>
                <dt>Ends</dt>
                <dd><%= new Date(auction.end_at).toLocaleString() %></dd>
              </div>
              <div>
                <dt>Items</dt>
                <dd><%= auction.asset_count %></dd>
              </div>
            </dl>
            <a class="btn" href="/auctions/<%= auction.id %>"><%= ctaLabel %></a>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>
<% } %>

<%
  renderAuctionGroup(
    "Live auctions",
    liveAuctions,
    "No auctions are currently live. Check back soon.",
    "View items & bid"
  );

  renderAuctionGroup(
    "Upcoming auctions",
    upcomingAuctions,
    "No upcoming auctions scheduled.",
    "Preview"
  );

  if (pastAuctions && pastAuctions.length) {
    renderAuctionGroup(
      "Past auctions",
      pastAuctions,
      "No past auctions yet.",
      "View results"
    );
  }
%>

<%- include("partials/footer") %>
