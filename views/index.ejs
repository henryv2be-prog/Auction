<%- include("partials/header", { title, user, notice, formError: null }) %>

<div class="public-toolbar">
  <div class="public-toolbar-inner">
    <p class="public-toolbar-eyebrow">Catalogue</p>
    <h1 class="public-toolbar-title"><%= title %></h1>
    <p class="public-toolbar-lead">
      Browse live, upcoming, and past auctions. Open one to see items and place bids when bidding is open.
    </p>
  </div>
</div>

<%
  function phaseLabel(phase) {
    if (phase === "live") return "Live";
    if (phase === "upcoming") return "Upcoming";
    return "Closed";
  }

  function phaseBadgeClass(phase) {
    if (phase === "live") return "badge badge-live";
    if (phase === "upcoming") return "badge badge-upcoming";
    return "badge badge-closed";
  }

  function renderAuctionGroup(heading, list, emptyText, ctaLabel, groupKey) {
%>
  <section class="section auction-group" data-auction-group="<%= groupKey %>">
    <div class="auction-group-header">
      <h2 class="section-heading"><%= heading %></h2>
      <span class="auction-group-count" data-auction-group-count><%= list.length %></span>
    </div>
    <% if (!list.length) { %>
      <p class="muted empty-inline" data-auction-group-empty><%= emptyText %></p>
    <% } else { %>
      <div class="grid" data-auction-group-grid>
        <% list.forEach((auction) => { %>
          <article
            class="card auction-card auction-card-rich<%= auction.feature_image_url ? '' : ' auction-card-no-image' %>"
            data-auction-card="<%= auction.id %>"
            data-auction-phase="<%= auction.phase %>"
          >
            <% if (auction.feature_image_url) { %>
              <a class="auction-card-media" href="/auctions/<%= auction.id %>" aria-hidden="true" tabindex="-1">
                <img
                  class="auction-card-cover"
                  src="<%= auction.feature_image_url %>"
                  alt=""
                  loading="lazy"
                  data-auction-feature-img
                />
              </a>
            <% } %>
            <div class="auction-card-body">
              <div class="card-header">
                <h3 data-auction-name><%= auction.name %></h3>
                <span
                  class="<%= phaseBadgeClass(auction.phase) %>"
                  data-auction-phase-badge
                ><%= phaseLabel(auction.phase) %></span>
              </div>
              <p class="muted" data-auction-description>
                <%= auction.description || "No description provided." %>
              </p>
              <dl class="detail-list">
                <div>
                  <dt>Starts (SAST)</dt>
                  <dd data-auction-start data-iso="<%= auction.start_at %>">
                    <%= formatSastDateTime(auction.start_at) %>
                  </dd>
                </div>
                <div>
                  <dt>Ends (SAST)</dt>
                  <dd data-auction-end data-iso="<%= auction.end_at %>">
                    <%= formatSastDateTime(auction.end_at) %>
                  </dd>
                </div>
                <div>
                  <dt>Items</dt>
                  <dd data-auction-asset-count><%= auction.asset_count %></dd>
                </div>
              </dl>
              <a class="btn" href="/auctions/<%= auction.id %>"><%= ctaLabel %></a>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>
<% } %>

<%
  renderAuctionGroup(
    "Live auctions",
    liveAuctions,
    "No auctions are currently live. Check back soon.",
    "View items & bid",
    "live"
  );

  renderAuctionGroup(
    "Upcoming auctions",
    upcomingAuctions,
    "No upcoming auctions scheduled.",
    "Preview",
    "upcoming"
  );

  renderAuctionGroup(
    "Past auctions",
    pastAuctions || [],
    "No past auctions yet.",
    "View results",
    "past"
  );
%>

<div data-realtime-root data-mode="auctions" hidden></div>

<script src="/socket.io/socket.io.js?v=<%= assetVersion %>"></script>
<script src="/realtime.js?v=<%= assetVersion %>"></script>

<%- include("partials/footer") %>
