<%- include("partials/header", { title, user, notice, formError: null }) %>

<section class="page-header">
  <h1>Live Auctions</h1>
  <p>Browse active auctions and available assets.</p>
</section>

<div class="grid">
  <% if (!auctions.length) { %>
    <article class="card">
      <h2>No auctions available</h2>
      <p class="muted">New auctions will appear here once published by the admin team.</p>
    </article>
  <% } %>

  <% auctions.forEach((auction) => { %>
    <article class="card">
      <div class="card-header">
        <h2><%= auction.name %></h2>
        <span class="badge <%= auction.status === 'open' ? 'badge-open' : 'badge-closed' %>">
          <%= auction.status.toUpperCase() %>
        </span>
      </div>
      <p class="muted"><%= auction.description || "No description provided." %></p>
      <dl class="detail-list">
        <div>
          <dt>Auction Date</dt>
          <dd><%= new Date(auction.auction_date).toLocaleString() %></dd>
        </div>
        <div>
          <dt>Total Assets</dt>
          <dd><%= auction.asset_count %></dd>
        </div>
      </dl>
      <a class="btn" href="/auctions/<%= auction.id %>">View Auction</a>
    </article>
  <% }) %>
</div>

<h2 class="section">Featured Assets</h2>
<div class="grid" data-realtime-root data-mode="listing">
  <% if (!assets.length) { %>
    <article class="card">
      <p>No assets available yet.</p>
    </article>
  <% } %>

  <% assets.forEach((asset) => { %>
    <article class="card" data-asset-card="<%= asset.id %>">
      <div class="card-header">
        <h2><%= asset.title %></h2>
        <span
          data-asset-status-badge
          class="badge <%= asset.status === 'open' ? 'badge-open' : 'badge-closed' %>"
        >
          <%= asset.status.toUpperCase() %>
        </span>
      </div>
      <p class="muted"><%= asset.description %></p>
      <dl class="detail-list">
        <div>
          <dt>Current Price</dt>
          <dd data-asset-price><%= formatCurrency(asset.current_price) %></dd>
        </div>
        <div>
          <dt>Start Price</dt>
          <dd><%= formatCurrency(asset.start_price) %></dd>
        </div>
        <div>
          <dt>Seller</dt>
          <dd><%= asset.seller_name %></dd>
        </div>
        <div>
          <dt>Ends</dt>
          <dd><%= new Date(asset.end_at).toLocaleString() %></dd>
        </div>
        <div>
          <dt>Bids</dt>
          <dd data-asset-bid-count><%= asset.bid_count %></dd>
        </div>
      </dl>
      <a class="btn" href="/assets/<%= asset.id %>">View Auction</a>
    </article>
  <% }) %>
</div>

<script src="/socket.io/socket.io.js"></script>
<script src="/realtime.js"></script>

<%- include("partials/footer") %>
