<%- include("partials/header", { title, user, notice, formError }) %>

<section
  id="asset-detail-root"
  class="detail-grid"
  data-realtime-root
  data-mode="detail"
  data-asset-id="<%= asset.id %>"
>
  <article class="asset-card">
    <h1><%= asset.title %></h1>
    <p><%= asset.description %></p>
    <dl class="asset-meta">
      <div>
        <dt>Seller</dt>
        <dd><%= asset.seller_name %></dd>
      </div>
      <div>
        <dt>Starting Price</dt>
        <dd><%= formatCurrency(asset.start_price) %></dd>
      </div>
      <div>
        <dt>Current Price</dt>
        <dd id="asset-current-price" data-current-price><%= formatCurrency(asset.current_price) %></dd>
      </div>
      <div>
        <dt>Status</dt>
        <dd>
          <span
            id="asset-status-pill"
            data-asset-status-pill
            class="pill <%= asset.status === 'open' ? 'pill-open' : 'pill-closed' %>"
          >
            <%= asset.status %>
          </span>
        </dd>
      </div>
      <div>
        <dt>Auction Ends</dt>
        <dd><%= new Date(asset.end_at).toLocaleString() %></dd>
      </div>
    </dl>

    <% if (media && media.length) { %>
      <section class="section">
        <h2>Media</h2>
        <div class="media-grid">
          <% media.forEach((item) => { %>
            <article class="media-card">
              <% if (item.media_type === "image") { %>
                <img src="<%= item.file_path %>" alt="<%= item.original_name %>" loading="lazy" />
              <% } else { %>
                <video controls preload="metadata">
                  <source src="<%= item.file_path %>" />
                  Your browser does not support video playback.
                </video>
              <% } %>
              <p class="muted media-name"><%= item.original_name %></p>
            </article>
          <% }) %>
        </div>
      </section>
    <% } %>
  </article>

  <aside class="panel">
    <h2>Place Bid</h2>
    <% if (!user) { %>
      <p>Please <a href="/login">login</a> as a user account to bid.</p>
    <% } else if (user.role !== "user") { %>
      <p>Admin accounts cannot place bids.</p>
    <% } else if (asset.status !== "open") { %>
      <p>This auction has closed.</p>
    <% } else { %>
      <form
        id="bid-form"
        data-bid-form
        method="post"
        action="/assets/<%= asset.id %>/bid"
        class="form"
      >
        <label for="amount">Bid Amount (ZAR)</label>
        <input id="amount" name="amount" type="number" min="0.01" step="0.01" required />
        <button id="submit-bid-button" class="btn" type="submit">Submit Bid</button>
      </form>
      <p id="min-bid-hint" class="muted">
        Your bid must be above <span data-minimum-bid><%= formatCurrency(asset.current_price) %></span>.
      </p>
      <p class="live-note muted" data-live-note>Live updates are enabled for this auction.</p>
    <% } %>
  </aside>
</section>

<section class="section">
  <h2>Recent Bids</h2>
  <% if (bids.length === 0) { %>
    <p id="no-bids-message" class="muted" data-bids-empty>No bids yet.</p>
  <% } else { %>
    <table class="table">
      <thead>
        <tr>
          <th>Bidder</th>
          <th>Amount</th>
          <th>Time</th>
        </tr>
      </thead>
      <tbody id="recent-bids-body" data-bids-body>
        <% bids.forEach((bid) => { %>
          <tr>
            <td><%= bid.bidder_name %></td>
            <td><%= formatCurrency(bid.amount) %></td>
            <td><%= new Date(bid.created_at).toLocaleString() %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</section>

<script src="/socket.io/socket.io.js"></script>
<script src="/realtime.js"></script>

<%- include("partials/footer") %>
