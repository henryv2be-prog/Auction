<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Auction Platform</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="/styles.css?v=<%= assetVersion %>" />
  <script>
    (function forceFreshClientAssets() {
      if (typeof window === "undefined") {
        return;
      }

      function cleanupLegacyCaches() {
        const tasks = [];

        if ("serviceWorker" in navigator) {
          tasks.push(
            navigator.serviceWorker
              .getRegistrations()
              .then(function (registrations) {
                return Promise.all(
                  registrations.map(function (registration) {
                    return registration.unregister();
                  })
                );
              })
              .catch(function () {})
          );
        }

        if ("caches" in window) {
          tasks.push(
            caches
              .keys()
              .then(function (cacheNames) {
                return Promise.all(
                  cacheNames.map(function (cacheName) {
                    return caches.delete(cacheName);
                  })
                );
              })
              .catch(function () {})
          );
        }

        return Promise.all(tasks);
      }

      function readStoredVersion(cacheKey) {
        try {
          return window.localStorage.getItem(cacheKey);
        } catch (error) {
          return null;
        }
      }

      function writeStoredVersion(cacheKey, value) {
        try {
          window.localStorage.setItem(cacheKey, value);
        } catch (error) {
          // ignore storage write failures in strict mobile privacy modes
        }
      }

      window.addEventListener("load", function () {
        const cacheVersion = "<%= assetVersion %>";
        const cacheKey = "auction-assets-version";
        const previousVersion = readStoredVersion(cacheKey);
        const url = new URL(window.location.href);
        const currentUrlVersion = url.searchParams.get("cv");
        const hasCurrentVersionTag = currentUrlVersion === cacheVersion;

        if (previousVersion !== cacheVersion || !hasCurrentVersionTag) {
          cleanupLegacyCaches().finally(function () {
            writeStoredVersion(cacheKey, cacheVersion);
            if (!hasCurrentVersionTag) {
              url.searchParams.set("cv", cacheVersion);
              // Full reload jumps scroll to top and breaks in-page browsing; if localStorage
              // already matches this deploy, only sync the URL without navigating.
              if (previousVersion === cacheVersion) {
                window.history.replaceState(null, "", url.toString());
              } else {
                window.location.replace(url.toString());
              }
            }
          });
          return;
        }

        cleanupLegacyCaches();
      });
    })();
  </script>
</head>
<body class="app-body<% if (adminLayout) { %> admin-body<% } %>">
  <header class="site-header" data-site-header data-nav-open="false">
    <div class="container header-row">
      <a class="brand" href="/">
        <span class="brand-mark" aria-hidden="true">A</span>
        <span class="brand-name">Auction Platform</span>
      </a>
      <button
        type="button"
        class="nav-toggle"
        data-nav-toggle
        aria-controls="primary-nav"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="nav-toggle-icon" aria-hidden="true"></span>
      </button>
      <nav id="primary-nav" class="nav-links" aria-label="Primary">
        <a href="/assets">Auctions</a>
        <% if (user) { %>
          <% if (user.role === "admin") { %>
            <a href="/admin/auctions">Dashboard</a>
          <% } else { %>
            <a href="/my-bids">My Bids</a>
          <% } %>
          <span class="nav-user"><%= user.name %> · <%= user.role %></span>
          <div class="nav-actions">
            <form action="/logout" method="post" class="inline-form">
              <button type="submit" class="btn btn-secondary btn-sm">Logout</button>
            </form>
          </div>
        <% } else { %>
          <div class="nav-actions">
            <a class="btn btn-secondary btn-sm" href="/login">Login</a>
            <a class="btn btn-sm" href="/register">Register</a>
          </div>
        <% } %>
      </nav>
    </div>
  </header>
  <script>
    (function setupMobileNavToggle() {
      var header = document.querySelector("[data-site-header]");
      var toggle = document.querySelector("[data-nav-toggle]");
      var nav = document.getElementById("primary-nav");
      if (!header || !toggle || !nav) {
        return;
      }
      function isOpen() {
        return header.getAttribute("data-nav-open") === "true";
      }
      function setOpen(open) {
        header.setAttribute("data-nav-open", open ? "true" : "false");
        toggle.setAttribute("aria-expanded", open ? "true" : "false");
      }
      toggle.addEventListener("click", function (event) {
        event.stopPropagation();
        setOpen(!isOpen());
      });
      nav.addEventListener("click", function (event) {
        var target = event.target;
        if (target && target.closest("a, button")) {
          setOpen(false);
        }
      });
      document.addEventListener("click", function (event) {
        if (!isOpen()) {
          return;
        }
        if (!header.contains(event.target)) {
          setOpen(false);
        }
      });
      document.addEventListener("keydown", function (event) {
        if (event.key === "Escape" && isOpen()) {
          setOpen(false);
          toggle.focus();
        }
      });
      window.addEventListener("resize", function () {
        if (window.matchMedia("(min-width: 768px)").matches) {
          setOpen(false);
        }
      });
    })();
  </script>
  <main class="container">
    <% if (notice) { %>
      <div class="alert alert-success"><%= notice %></div>
    <% } %>
    <% if (formError) { %>
      <div class="alert alert-error"><%= formError %></div>
    <% } %>
