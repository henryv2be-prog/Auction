<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Auction Platform</title>
  <link rel="stylesheet" href="/styles.css?v=<%= assetVersion %>" />
  <script>
    (function forceFreshClientAssets() {
      if (typeof window === "undefined") {
        return;
      }

      function cleanupLegacyCaches() {
        const tasks = [];

        if ("serviceWorker" in navigator) {
          tasks.push(
            navigator.serviceWorker
              .getRegistrations()
              .then(function (registrations) {
                return Promise.all(
                  registrations.map(function (registration) {
                    return registration.unregister();
                  })
                );
              })
              .catch(function () {})
          );
        }

        if ("caches" in window) {
          tasks.push(
            caches
              .keys()
              .then(function (cacheNames) {
                return Promise.all(
                  cacheNames.map(function (cacheName) {
                    return caches.delete(cacheName);
                  })
                );
              })
              .catch(function () {})
          );
        }

        return Promise.all(tasks);
      }

      function readStoredVersion(cacheKey) {
        try {
          return window.localStorage.getItem(cacheKey);
        } catch (error) {
          return null;
        }
      }

      function writeStoredVersion(cacheKey, value) {
        try {
          window.localStorage.setItem(cacheKey, value);
        } catch (error) {
          // ignore storage write failures in strict mobile privacy modes
        }
      }

      window.addEventListener("load", function () {
        const cacheVersion = "<%= assetVersion %>";
        const cacheKey = "auction-assets-version";
        const previousVersion = readStoredVersion(cacheKey);
        const url = new URL(window.location.href);
        const currentUrlVersion = url.searchParams.get("cv");
        const hasCurrentVersionTag = currentUrlVersion === cacheVersion;

        if (previousVersion !== cacheVersion || !hasCurrentVersionTag) {
          cleanupLegacyCaches().finally(function () {
            writeStoredVersion(cacheKey, cacheVersion);
            if (!hasCurrentVersionTag) {
              url.searchParams.set("cv", cacheVersion);
              window.location.replace(url.toString());
            }
          });
          return;
        }

        cleanupLegacyCaches();
      });
    })();
  </script>
</head>
<body>
  <header class="site-header">
    <div class="container header-row">
      <a class="brand" href="/">Auction Platform</a>
      <nav class="nav-links">
        <% if (user) { %>
          <a href="/assets">Assets</a>
          <% if (user.role === "admin") { %>
            <a href="/admin/auctions">Auctions</a>
            <a href="/admin">Admin</a>
          <% } else { %>
            <a href="/my-bids">My Bids</a>
          <% } %>
          <span class="nav-user"><%= user.name %> (<%= user.role %>)</span>
          <form action="/logout" method="post" class="inline-form">
            <button type="submit" class="btn btn-secondary">Logout</button>
          </form>
        <% } else { %>
          <a href="/login">Login</a>
          <a href="/register">Register</a>
        <% } %>
      </nav>
    </div>
  </header>
  <main class="container">
    <% if (notice) { %>
      <div class="alert alert-success"><%= notice %></div>
    <% } %>
    <% if (formError) { %>
      <div class="alert alert-error"><%= formError %></div>
    <% } %>
