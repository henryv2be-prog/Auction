<%- include("partials/header", { title, user, notice, formError }) %>

<div class="public-toolbar public-toolbar-minimal">
  <h1 class="public-toolbar-title">Create account</h1>
  <p class="public-toolbar-lead">Register as a bidder to join live auctions and track your bids.</p>
</div>

<section class="auth-card">
  <form action="/register" method="post" class="stack-form">
    <label for="name">Full name</label>
    <input id="name" name="name" type="text" autocomplete="name" required />

    <label for="email">Email</label>
    <input id="email" name="email" type="email" autocomplete="email" required />

    <label for="password">Password</label>
    <input id="password" name="password" type="password" minlength="6" autocomplete="new-password" required />

    <button class="btn btn-block" type="submit">Register</button>
  </form>

  <p class="muted auth-card-footer">Already registered? <a href="/login">Sign in</a></p>
</section>

<%- include("partials/footer") %>
