<%- include("partials/header", { title, user, notice, formError }) %>

<div class="admin-toolbar">
  <div class="admin-toolbar-inner">
    <nav class="admin-breadcrumb" aria-label="Admin">
      <a href="/admin/auctions">Auctions</a>
      <span aria-hidden="true" class="admin-breadcrumb-sep">/</span>
      <a href="/admin/auctions/<%= auction.id %>/edit"><%= auction.name %></a>
      <span aria-hidden="true" class="admin-breadcrumb-sep">/</span>
      <span class="admin-breadcrumb-current">Edit item</span>
    </nav>
    <h1 class="admin-page-title"><%= asset.title %></h1>
    <p class="admin-toolbar-lead muted">Update listing copy, schedule, media, and bidding state.</p>
  </div>
</div>

<div class="admin-layout admin-layout-single">
  <section class="admin-panel admin-panel-accent">
    <div class="admin-panel-head">
      <h2 class="admin-panel-title">Listing details</h2>
      <p class="admin-panel-desc">Saving applies to this item only.</p>
    </div>
    <form
      method="post"
      action="/admin/assets/<%= asset.id %>/edit"
      enctype="multipart/form-data"
      class="grid-form admin-form-tight"
      data-upload-form
    >
      <label>
        Title
        <input type="text" name="title" value="<%= asset.title %>" required />
      </label>
      <label>
        Starting price (ZAR)
        <input type="number" name="startPrice" value="<%= asset.start_price %>" step="0.01" min="0.01" required />
      </label>
      <label class="full-row">
        Description
        <textarea name="description" rows="4" required><%= asset.description %></textarea>
      </label>
      <label>
        Item ends (SAST)
        <input
          type="datetime-local"
          name="endAt"
          value="<%= formatForDatetimeLocalInput(asset.end_at) %>"
          required
        />
      </label>
      <label>
        Bidding
        <select name="status">
          <option value="open" <%= asset.status === "open" ? "selected" : "" %>>Open</option>
          <option value="closed" <%= asset.status === "closed" ? "selected" : "" %>>Closed</option>
        </select>
      </label>
      <label class="full-row">
        Add media
        <input type="file" name="media" accept="image/*,video/*" multiple />
      </label>
      <p class="muted full-row upload-help">Existing photos and videos stay on the item unless you remove them below.</p>
      <div class="button-row">
        <button type="submit" class="btn">Save changes</button>
        <a class="btn btn-secondary" href="/admin/auctions/<%= auction.id %>/edit">Back to auction</a>
        <a class="btn btn-ghost" href="/assets/<%= asset.id %>">Public listing</a>
      </div>
    </form>
  </section>

  <section class="admin-panel">
    <div class="admin-panel-head">
      <h2 class="admin-panel-title">Media library</h2>
      <p class="admin-panel-desc">Remove files you no longer want shown to bidders.</p>
    </div>
    <% if (!media.length) { %>
      <div class="empty-state admin-empty">
        <p class="admin-empty-title">No media yet</p>
        <p class="muted">Upload images or video using the form above.</p>
      </div>
    <% } else { %>
      <div class="media-grid">
        <% media.forEach((item) => { %>
          <article class="media-card">
            <% if (item.media_type === "image") { %>
              <img src="<%= item.file_path %>" alt="<%= item.original_name %>" loading="lazy" />
            <% } else { %>
              <video controls preload="metadata">
                <source src="<%= item.file_path %>" />
              </video>
            <% } %>
            <div class="media-card-actions">
              <p class="media-caption"><%= item.original_name %></p>
              <form method="post" action="/admin/media/<%= item.id %>/delete">
                <button type="submit" class="btn btn-danger-ghost btn-sm">Remove</button>
              </form>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>
</div>

<script src="/upload-progress.js?v=<%= assetVersion %>"></script>

<%- include("partials/footer") %>
