<%- include("partials/header", { title, user, notice, formError }) %>

<section class="hero">
  <h1>Admin Dashboard</h1>
  <p>Create assets and manage active auctions.</p>
</section>

<section class="card">
  <h2>Add Auction Asset</h2>
  <form action="/admin/assets" method="post" class="grid-form">
    <label>
      Asset title
      <input type="text" name="title" required />
    </label>
    <label>
      Start price
      <input type="number" name="startPrice" step="0.01" min="0.01" required />
    </label>
    <label class="full-row">
      Description
      <textarea name="description" rows="4" required></textarea>
    </label>
    <label>
      Auction ends at
      <input type="datetime-local" name="endAt" required />
    </label>
    <div class="button-row">
      <button type="submit" class="btn">Create Auction</button>
    </div>
  </form>
</section>

<section class="card">
  <h2>Managed Assets</h2>
  <% if (!assets.length) { %>
    <p>No assets have been created yet.</p>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Title</th>
            <th>Status</th>
            <th>Current Price</th>
            <th>Bids</th>
            <th>Ends</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% assets.forEach((asset) => { %>
            <tr>
              <td><%= asset.id %></td>
              <td><a href="/assets/<%= asset.id %>"><%= asset.title %></a></td>
              <td>
                <span class="status <%= asset.status %>"><%= asset.status %></span>
              </td>
              <td>$<%= Number(asset.current_price).toFixed(2) %></td>
              <td><%= asset.bid_count %></td>
              <td><%= new Date(asset.end_at).toLocaleString() %></td>
              <td>
                <% if (asset.status === "open") { %>
                  <form action="/admin/assets/<%= asset.id %>/close" method="post">
                    <button type="submit" class="btn btn-secondary">Close</button>
                  </form>
                <% } else { %>
                  Closed
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<%- include("partials/footer") %>
